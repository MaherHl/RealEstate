@model RealEstate2.Models.facility;
@Html.Partial("_Dashbord")



<section class="max-w-4xl p-6 mx-auto bg-white rounded-md shadow-md  mt-10">
    <h2 class="text-base font-semibold leading-7 text-gray-900"> Edit Property</h2>
    <p class="mt-1 text-sm leading-6 text-gray-600">This information will be displayed publicly so be careful what you share.</p>
    <form asp-controller="Facility" asp-action="Edit" method="post">
        <div class="grid grid-cols-1 gap-6 mt-4 sm:grid-cols-2">
            <div>
                <label class="text-black" for="">Facilty Name</label>
                <input id="username" asp-for="FacilityName" type="text" class="block w-full px-4 py-2 mt-2 text-black bg-gray-50 border border-black-50 rounded-md  focus:border-blue-500 dark:focus:border-blue-500 focus:outline-none focus:ring">
            </div>

            <div>
                <label class="text-black" for="emailAddress"> Google Maps Address</label>
                <input id="emailAddress" asp-for="location" type="text" class="block w-full px-4 py-2 mt-2 text-black bg-gray-50 border border-black-50 rounded-md  focus:border-blue-500 dark:focus:border-blue-500 focus:outline-none focus:ring">
            </div>

            <div>
                <label class="text-black" for="">City</label>
                <input id="" type="text" asp-for="City" class="block w-full px-4 py-2 mt-2 text-black bg-gray-50 border border-black-50 rounded-md bg-gray-50  focus:border-blue-500  focus:outline-none focus:ring">
            </div>

            <div>
                <label class="text-black" for="">Price</label>
                <input id="" type="text" asp-for="Price" class="block w-full px-4 py-2 mt-2 text-black bg-gray-50 border border-black-50 rounded-md  focus:border-blue-500 focus:outline-none focus:ring">
            </div>
            <div>
                <label class="text-black" for="">Rooms Number</label>
                <input id="" type="number" asp-for="rooms" class="block w-full px-4 py-2 mt-2 text-black bg-gray-50 border border-black-50 rounded-md  focus:border-blue-500 focus:outline-none focus:ring">
            </div>
            <div>
                <label class="text-black" for="">Property type</label>
                <select asp-for="PropertyType" class="block w-full px-4 py-2 mt-2 text-gray-700 bg-gray-50 border border-Black rounded-md  focus:border-blue-500 dark:focus:border-blue-500 focus:outline-none focus:ring">
                    <option>Studio</option>
                    <option>Appartement</option>
                    <option>Desk</option>

                </select>
            </div>
            <div class="flex items-center mb-4">
                <input asp-for="isPetFriendly" id="default-checkbox" type="checkbox"  class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600">
                <label for="default-checkbox" class="ms-2 text-sm font-medium text-gray-900 ">Default checkbox</label>
            </div>

            <div>
                <label class="text-black" for="">Renting type</label>
                <select asp-for="rentingType" class="block w-full px-4 py-2 mt-2 text-gray-700 bg-gray-50 border border-Black rounded-md  focus:border-blue-500 dark:focus:border-blue-500 focus:outline-none focus:ring">
                    <option>daily</option>
                    <option>Monthly</option>
                </select>
            </div>
            <div>
                <label class="text-black" for="">Description</label>
                <textarea id="textarea" asp-for="description" type="textarea" class="block w-full px-4 py-2 mt-2 text-black bg-gray-50 border border-black-50 rounded-md  focus:border-blue-500  focus:outline-none focus:ring"></textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-black">
                    Image
                </label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md">
                    <div class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-white" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="flex text-sm text-gray-600">
                            <label for="file-upload" class="relative cursor-pointer bg-gray-50 rounded-md font-medium text-indigo-600 hover:text-indigo-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500">
                                <span class="">Upload a file</span>
                                <input id="file-upload" name="file-upload" type="file" class="sr-only">
                            </label>
                            <p class="pl-1 text-gray-500">or drag and drop</p>
                        </div>
                        <p class="text-xs text-gray-500">
                            PNG, JPG, GIF up to 10MB
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex justify-end mt-6">
            <button type="submit" class="px-6 py-2 leading-5 text-white transition-colors duration-200 transform bg-pink-500 rounded-md hover:bg-pink-700 focus:outline-none focus:bg-gray-600">Save</button>
        </div>
    </form>
</section>




